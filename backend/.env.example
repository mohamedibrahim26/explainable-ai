# ── Database ─────────────────────────────────────────────────────────────────
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://postgres:yourpassword@localhost:5432/orionai"

# ── JWT Secrets (change these to long random strings in production) ───────────
JWT_SECRET="orion-jwt-secret-change-this-to-something-long-and-random"
JWT_REFRESH_SECRET="orion-refresh-secret-change-this-too"

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001

# ── Frontend URL (for CORS) ───────────────────────────────────────────────────
# Use the URL where your index.html is served from (e.g. Live Server default)
FRONTEND_URL="http://127.0.0.1:5500"

# ── Admin access ──────────────────────────────────────────────────────────────
# Comma-separated list of email addresses that can access /api/admin/* routes
# and the admin dashboard at admin.html
ADMIN_EMAILS="ibrahim764566@gmail.com"
