# ── LLM Provider Keys (set at least ONE) ─────────────────────────────────────
OPENAI_API_KEY=sk-...           # GPT-4o, GPT-4o-mini
ANTHROPIC_API_KEY=sk-ant-...    # Claude 3.5 Sonnet, Claude 3 Haiku
GROQ_API_KEY=gsk_...                # Llama-3.3-70b (free tier available)
GEMINI_API_KEY=AIza...          # Gemini 1.5 Pro, Gemini 1.5 Flash

# Ollama runs LOCALLY — no key needed, just install ollama.ai
OLLAMA_BASE_URL=http://localhost:11434

# ── Default provider + fallback chain ────────────────────────────────────────
# Provider tried first. If it fails, tries the next in FALLBACK_CHAIN.
DEFAULT_PROVIDER=groq
FALLBACK_CHAIN=groq,openai,anthropic,gemini,ollama

# ── Embedding model ───────────────────────────────────────────────────────────
# "local"  → sentence-transformers (free, runs offline)
# "openai" → text-embedding-3-small (costs money, more accurate)
EMBEDDING_PROVIDER=local

# ── ChromaDB ─────────────────────────────────────────────────────────────────
CHROMA_PERSIST_DIR=./chroma_db

# ── Service ───────────────────────────────────────────────────────────────────
AI_SERVICE_PORT=8000
AI_SERVICE_SECRET=change-me-in-production   # Node backend uses this to auth
CORS_ORIGINS=http://localhost:3001,http://127.0.0.1:5500,http://localhost:5500
